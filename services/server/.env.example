# Server
PORT=8000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://memory:memory_secret@localhost:5432/memory

# OpenAI-compatible API (for embedding)
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# MySo Network (for onchain verification)
# Controls all network-dependent defaults (RPC, File Storage, MYDATA)
MYSO_NETWORK=mainnet
MYSO_RPC_URL=https://fullnode.mainnet.mysosocial.network:443

# File Storage (publisher + aggregator)
FILE_STORAGE_PUBLISHER_URL=https://publisher.file-storage-mainnet.mysocial.network
FILE_STORAGE_AGGREGATOR_URL=https://aggregator.file-storage-mainnet.mysocial.network

# Server wallet (deployer = TEE admin) — required for MYDATA decrypt
SERVER_MYSO_PRIVATE_KEY=mysoprivkey1...

# Key pool for parallel File Storage uploads (up to 5 wallets round-robin)
# Each wallet needs MYSO + WAL tokens
SERVER_MYSO_PRIVATE_KEYS=mysoprivkey1...,mysoprivkey1...

# Contract IDs — required
MEMORY_PACKAGE_ID=0x...
MEMORY_REGISTRY_ID=0x...

# MYDATA key servers (comma-separated object IDs; each ID must be unique —
# duplicates are ignored at runtime)
# Required for MYDATA encrypt/decrypt in sidecar scripts
MYDATA_KEY_SERVERS=0x...,0x...

# MYDATA threshold — minimum number of key servers that must respond for
# encrypt/decrypt to succeed. Must be ≤ number of entries in MYDATA_KEY_SERVERS.
# Default: 2 (requires at least 2 key servers configured above)
MYDATA_THRESHOLD=2
MYDATA_DECRYPT_THRESHOLD=2

# File Storage on-chain package ID (auto-detected from MYSO_NETWORK if not set)
# FILE_STORAGE_PACKAGE_ID=0x...

# File Storage upload relay (auto-detected from MYSO_NETWORK if not set)
# FILE_STORAGE_UPLOAD_RELAY_URL=https://upload-relay.mainnet.mysocial.network

# Enoki Sponsored Transactions (sidecar)
ENOKI_API_KEY=
ENOKI_NETWORK=mainnet

# Sponsor endpoint rate limiting (per IP + per sender, sliding window)
SPONSOR_RATE_LIMIT_PER_MINUTE=10
SPONSOR_RATE_LIMIT_PER_HOUR=30

# CORS — comma-separated list of allowed browser origins
# If unset, CORS is deny-all (browsers blocked) — always set this in production
#
# Production:
# ALLOWED_ORIGINS=https://mysocial.network,https://noter.demo.mysocial.network,https://chatbot.demo.mysocial.network,https://researcher.demo.mysocial.network
#
# Staging:
# ALLOWED_ORIGINS=https://testnet.mysocial.network,https://noter.demo.testnet.mysocial.network,https://chatbot.demo.testnet.mysocial.network,https://researcher.demo.testnet.mysocial.network
#
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000
