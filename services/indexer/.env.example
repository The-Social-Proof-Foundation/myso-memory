# Database (same PostgreSQL as server — shared instance)
DATABASE_URL=postgresql://memory:memory_secret@localhost:5432/memory

# If the indexer panics with "permission denied for schema public" (SQLSTATE 42501),
# your DB user cannot CREATE in schema public (common on PostgreSQL 15+ or managed Postgres).
# Fix: as superuser run services/server/postgres-init/00-grant-public.sql, or GRANT USAGE, CREATE
# ON SCHEMA public TO your_user; then restart the indexer. Fresh Docker setups (compose + empty
# volume) run that script automatically on first Postgres start.

# MySo Network
MYSO_RPC_URL=https://fullnode.testnet.mysosocial.network:443

# Memory contract package ID (for event filtering)
MEMORY_PACKAGE_ID=0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6

# Polling interval in seconds
POLL_INTERVAL_SECS=5
