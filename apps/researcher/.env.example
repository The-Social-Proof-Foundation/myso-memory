# OpenRouter API key — chat, LLM chunking, and embeddings
# Get it from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# PostgreSQL (with pgvector extension)
# Local: postgresql://user:pass@localhost:5432/researcher
POSTGRES_URL=

# memory SDK — Ed25519 delegate key for memory layer
MEMORY_KEY=
MEMORY_SERVER_URL=http://localhost:3001

# Auth secret for JWT session signing
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Redis (optional) — used for resumable streams and IP rate limiting
# If not set, rate limiting is skipped and streams are non-resumable
REDIS_URL=

# Vercel Blob (optional) — used for file uploads (images, PDFs)
BLOB_READ_WRITE_TOKEN=

# Enoki zkLogin (optional) — enables "Sign in with Google"
# Get Enoki API key from https://portal.enoki.mystenlabs.com
# Get Google Client ID from https://console.cloud.google.com
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_MYSO_NETWORK=testnet
NEXT_PUBLIC_MEMORY_PACKAGE_ID=
NEXT_PUBLIC_MEMORY_REGISTRY_ID=
NEXT_PUBLIC_MEMORY_SERVER_URL=http://localhost:9000
