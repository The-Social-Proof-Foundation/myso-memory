{
  "name": "memory-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:sdk": "pnpm --filter @socialproof/memory build",
    "dev:sdk": "pnpm --filter @socialproof/memory dev",
    "dev:noter": "pnpm --filter noter dev",
    "dev:chatbot": "pnpm --filter chatbot dev",
    "dev:app": "pnpm --filter app dev",
    "dev:researcher": "pnpm --filter researcher dev",
    "dev:docs": "pnpm --filter memory-docs dev",
    "build:docs": "pnpm --filter memory-docs build",
    "preview:docs": "pnpm --filter memory-docs serve",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*",
    "docs"
  ]
}
